/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 通用容器 */
.container {
  padding: 30rpx;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 标题样式 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #FF6B6B;
}

/* 按钮样式 */
.btn {
  padding: 24rpx 48rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  text-align: center;
  margin: 16rpx 0;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
}

.btn-outline {
  border: 2rpx solid #FF6B6B;
  color: #FF6B6B;
  background: #fff;
}

.btn-disabled {
  background: #ccc;
  color: #fff;
}

/* 输入框样式 */
.input-wrapper {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.input-field {
  font-size: 28rpx;
  color: #333;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-draft {
  background: #f0f0f0;
  color: #999;
}

.status-recruiting {
  background: #e6f7ff;
  color: #1890ff;
}

.status-completed {
  background: #fff7e6;
  color: #faad14;
}

.status-published {
  background: #f6ffed;
  color: #52c41a;
}

/* 类型标签 */
.type-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  margin-right: 8rpx;
}

.type-original {
  background: #fff1f0;
  color: #ff4d4f;
}

.type-cover {
  background: #f0f5ff;
  color: #597ef7;
}

/* 音乐类型标签 */
.music-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: #f5f5f5;
  color: #666;
  margin: 8rpx;
}

/* Flex布局工具类 */
.flex {
  display: flex;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-center {
  justify-content: center;
  align-items: center;
}

.flex-between {
  justify-content: space-between;
  align-items: center;
}

.flex-col {
  flex-direction: column;
}

.flex-1 {
  flex: 1;
}

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }

/* 文字 */
.text-primary { color: #FF6B6B; }
.text-gray { color: #999; }
.text-small { font-size: 24rpx; }
.text-center { text-align: center; }

/* 分割线 */
.divider {
  height: 1rpx;
  background: #eee;
  margin: 30rpx 0;
}
