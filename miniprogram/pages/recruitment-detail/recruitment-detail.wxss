/* 招募详情页样式 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 封面区域 */
.cover-section {
  position: relative;
  height: 400rpx;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
}

.cover-type, .cover-status {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #fff;
}

.cover-type.type-original {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
}

.cover-type.type-cover {
  background: linear-gradient(135deg, #597ef7, #7b9fff);
}

.cover-status.status-recruiting {
  background: rgba(24, 144, 255, 0.9);
}

.cover-status.status-completed {
  background: rgba(250, 173, 20, 0.9);
}

.cover-status.status-published {
  background: rgba(82, 196, 26, 0.9);
}

/* 卡片样式 */
.card {
  background: #fff;
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 基本信息 */
.info-section .info-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.info-creator {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.creator-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.creator-detail {
  display: flex;
  flex-direction: column;
}

.creator-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.creator-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.divider {
  height: 1rpx;
  background: #eee;
  margin: 30rpx 0;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.info-value.expired {
  color: #ff4d4f;
}

.budget-value {
  color: #FF6B6B;
  font-weight: 500;
}

.info-tags {
  padding: 16rpx 0;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

/* 外部链接 */
.info-links {
  padding: 16rpx 0;
}

.links-list {
  margin-top: 12rpx;
}

.link-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.link-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.link-text {
  flex: 1;
  font-size: 26rpx;
  color: #1890ff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.link-tip {
  font-size: 22rpx;
  color: #999;
  margin-left: 12rpx;
}

/* 描述文本 */
.description-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 参与者列表 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.admin-actions {
  display: flex;
}

.action-btn {
  padding: 8rpx 20rpx;
  background: #FF6B6B;
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.participants-list {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.participant-item {
  text-align: center;
  position: relative;
}

.remove-btn {
  margin-top: 8rpx;
  padding: 4rpx 12rpx;
  background: #ff4d4f;
  color: #fff;
  border-radius: 16rpx;
  font-size: 20rpx;
}

.participant-main {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.participant-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
}

.participant-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.participant-name-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.participant-name {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100rpx;
}

.creator-badge {
  font-size: 18rpx;
  color: #faad14;
  white-space: nowrap;
}

.participant-role {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-participants {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

/* 安全区域适配 */
.safe-area-bottom {
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

/* 编辑按钮（左侧） */
.edit-btn-wrap {
  flex-shrink: 0;
  margin-right: 20rpx;
}

.btn-edit {
  padding: 20rpx 32rpx;
  background: #fff;
  border: 2rpx solid #FF6B6B;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #FF6B6B;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.2);
}

.btn-edit:active {
  opacity: 0.8;
}

/* 右侧操作区 */
.action-right {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
}

/* 状态提示 */
.status-hint {
  padding: 8rpx 0;
}

.status-text {
  font-size: 26rpx;
  font-weight: 500;
}

.status-text.pending,
.status-text.status-pending {
  color: #faad14;
}

.status-text.approved,
.status-text.status-approved {
  color: #52c41a;
}

.status-text.rejected,
.status-text.status-rejected {
  color: #ff4d4f;
}

/* 按钮组 */
.btn-group {
  display: flex;
  gap: 16rpx;
}

.btn-group .btn {
  padding: 20rpx 40rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 主要操作按钮 */
.btn-apply {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
}

.btn-apply:active {
  opacity: 0.8;
}

/* 待审核按钮 */
.btn-pending {
  background: #faad14;
  color: #fff;
}

/* 成功按钮 */
.btn-success {
  background: #52c41a;
  color: #fff;
}

/* 主按钮（登录） */
.btn-primary {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  color: #999;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.modal-mask.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.input-item {
  margin-bottom: 30rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.input-label .optional {
  font-size: 24rpx;
  color: #999;
}

.input-field {
  width: 100%;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  min-height: 80rpx;
  line-height: 1.4;
}

.input-textarea {
  width: 100%;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  min-height: 160rpx;
  line-height: 1.6;
}

.link-tip {
  padding: 16rpx 20rpx;
  background: #fff7e6;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #faad14;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eee;
}

.modal-footer .btn {
  flex: 1;
  margin: 0 10rpx;
}

/* 确认弹窗 */
.confirm-modal {
  max-width: 600rpx;
  margin: 200rpx auto;
  border-radius: 24rpx;
  position: relative;
}

.confirm-text {
  text-align: center;
  font-size: 30rpx;
  color: #333;
  padding: 40rpx 0;
}

.confirm-text .highlight {
  color: #ff4d4f;
  font-weight: bold;
}

.confirm-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 危险按钮 */
.btn-danger {
  background: #ff4d4f;
  color: #fff;
  border: none;
}

/* 成功按钮 */
.btn-success {
  background: #52c41a;
  color: #fff;
  border: none;
}

/* 职位需求样式 */
.position-demand-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.position-demand-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.position-demand-info {
  display: flex;
  flex-direction: column;
}

.position-demand-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.position-demand-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 发布链接样式 */
.publish-link {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #f6ffed, #e6fff0);
  border: 2rpx solid #52c41a;
  border-radius: 12rpx;
}

.publish-link .link-icon {
  width: 36rpx;
  height: 36rpx;
}

.publish-url-text {
  color: #52c41a !important;
  font-weight: 500;
}

.position-demand-status {
  display: flex;
  align-items: center;
}

.position-demand-status .current-count {
  font-size: 32rpx;
  font-weight: bold;
  color: #1890ff;
}

.position-demand-status .total-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

.demand-badge {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
}

.demand-badge.need {
  background: #e6f7ff;
  color: #1890ff;
}

.demand-badge.full {
  background: #f6ffed;
  color: #52c41a;
}

/* 申请弹窗中的职位选择 */
.role-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}

.role-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  min-width: 140rpx;
}

.role-option.selected {
  background: #e6f7ff;
  border-color: #1890ff;
}

.role-option .role-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.role-option.selected .role-name {
  color: #1890ff;
}

.role-option .role-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.role-option.selected .role-desc {
  color: #1890ff;
}

/* 参与者专属卡片 */
.participant-card {
  background: linear-gradient(135deg, #f6ffed, #e6fff0);
  border: 2rpx solid #b7eb8f;
}

.participant-card .section-header {
  margin-bottom: 20rpx;
}

.participant-badge {
  background: #52c41a;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.team-channel {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #d9f7be;
}

.team-channel:last-of-type {
  border-bottom: none;
}

.channel-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666;
}

.channel-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.team-notes {
  display: flex;
  flex-direction: column;
  padding-top: 16rpx;
  margin-top: 8rpx;
  border-top: 1rpx dashed #b7eb8f;
}

.notes-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.notes-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  white-space: pre-wrap;
}
