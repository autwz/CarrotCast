/* 消息详情页面样式 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 消息头部 */
.message-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.header-icon {
  width: 64rpx;
  height: 64rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.header-icon image {
  width: 100%;
  height: 100%;
}

.header-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.message-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.message-time {
  font-size: 24rpx;
  color: #999;
}

.divider {
  height: 1rpx;
  background: #eee;
  margin: 24rpx 0;
}

/* 消息内容 */
.message-body {
  padding: 10rpx 0;
}

.message-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
}

/* 关联招募 */
.related-recruitment {
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.recruitment-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.recruitment-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recruitment-title {
  font-size: 28rpx;
  color: #1890ff;
}

.recruitment-arrow {
  font-size: 32rpx;
  color: #999;
}

/* 操作按钮 */
.action-section {
  display: flex;
  gap: 20rpx;
  padding-top: 10rpx;
}

.action-section .btn {
  flex: 1;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  color: #999;
}
