<view class="page">
  <!-- 操作栏 -->
  <view class="action-bar" wx:if="{{messageList.length > 0}}">
    <text class="unread-count" wx:if="{{unreadCount > 0}}">未读消息: {{unreadCount}}</text>
    <text class="mark-all" bindtap="markAllRead">全部标为已读</text>
  </view>

  <!-- 消息列表 -->
  <scroll-view class="list-container" scroll-y bindscrolltolower="onLoadMore">
    <view class="message-list">
      <view 
        class="message-card {{item.status === 'unread' ? 'unread' : ''}}" 
        wx:for="{{messageList}}" 
        wx:key="_id"
        bindtap="goToDetail"
        data-id="{{item._id}}"
      >
        <view class="message-icon">
          <image src="/images/icons/{{getMessageIcon(item.type)}}.png" mode="aspectFit"></image>
        </view>
        <view class="message-content">
          <view class="message-header">
            <text class="message-title">{{item.title}}</text>
            <text class="message-time">{{getRelativeTime(item.createTime)}}</text>
          </view>
          <text class="message-preview">{{item.content}}</text>
          <view class="message-footer">
            <text class="recruitment-name" wx:if="{{item.recruitmentTitle}}" bindtap="goToRecruitment" data-id="{{item.recruitmentId}}">
              {{item.recruitmentTitle}} ›
            </text>
          </view>
        </view>
        <view class="unread-dot" wx:if="{{item.status === 'unread'}}"></view>
      </view>

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{hasMore && messageList.length > 0}}">
        <text wx:if="{{loading}}">加载中...</text>
        <text wx:else bindtap="onLoadMore">加载更多</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{messageList.length === 0 && !loading}}">
      <image src="/images/icons/empty-message.png" mode="aspectFit"></image>
      <text>暂无站内信</text>
    </view>
  </scroll-view>
</view>
