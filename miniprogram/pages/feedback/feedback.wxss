.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 反馈表单 */
.feedback-form .form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.feedback-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.form-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.char-count {
  font-size: 24rpx;
  color: #999;
}

.char-count.over {
  color: #ff4d4f;
}

.submit-btn {
  padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.submit-btn:active {
  opacity: 0.8;
}
