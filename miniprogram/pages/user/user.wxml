<view class="page">
    <!-- 未登录状态 -->
  <view class="login-section" wx:if="{{!isLoggedIn}}">
    <image class="login-avatar" src="/images/icons/avatar.png" mode="aspectFill"></image>
    <text class="login-hint">登录后享受更多功能</text>
    <button class="btn btn-primary login-btn" bindtap="onLogin">微信一键登录</button>
  </view>

  <!-- 已登录状态 -->
  <block wx:else>
    <!-- 用户信息卡片 -->
    <view class="user-card card">
      <view class="user-info" bindtap="goToEditProfile">
        <image class="user-avatar" src="{{userInfo.avatar || '/images/icons/avatar.png'}}" mode="aspectFill"></image>
        <view class="user-detail">
          <text class="user-nickname">{{userInfo.nickname || '未设置昵称'}}</text>
          <text class="user-bio">{{userInfo.bio || '这个人很懒，什么都没写'}}</text>
        </view>
        <view class="edit-icon">›</view>
      </view>

      <view class="contact-info">
        <view class="contact-row" wx:if="{{userInfo.qq}}">
          <text class="contact-label">QQ</text>
          <text class="contact-value">{{userInfo.qq}}</text>
        </view>
        <view class="contact-row" wx:else bindtap="goToEditProfile">
          <text class="contact-label">QQ</text>
          <text class="contact-empty">去设置 ›</text>
        </view>
        
        <view class="contact-row" wx:if="{{userInfo.wechat}}">
          <text class="contact-label">微信</text>
          <text class="contact-value">{{userInfo.wechat}}</text>
        </view>
        <view class="contact-row" wx:else bindtap="goToEditProfile">
          <text class="contact-label">微信</text>
          <text class="contact-empty">去设置 ›</text>
        </view>
        
        <view class="contact-row" wx:if="{{userInfo.phone}}">
          <text class="contact-label">电话</text>
          <text class="contact-value">{{userInfo.phone}}</text>
        </view>
        <view class="contact-row" wx:else bindtap="goToEditProfile">
          <text class="contact-label">电话</text>
          <text class="contact-empty">去设置 ›</text>
        </view>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-section card">
      <view class="menu-item" bindtap="goToMyRecruitments">
        <view class="menu-left">
          <image class="menu-icon" src="/images/icons/recruitment.png" mode="aspectFit"></image>
          <text class="menu-text">我的招募</text>
        </view>
        <view class="menu-right">
          <text class="menu-badge" wx:if="{{myRecruitmentCount > 0}}">{{myRecruitmentCount}}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <view class="menu-item" bindtap="goToMessages">
        <view class="menu-left">
          <image class="menu-icon" src="/images/icons/message.png" mode="aspectFit"></image>
          <text class="menu-text">站内信</text>
        </view>
        <view class="menu-right">
          <text class="menu-badge badge-red" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 创建招募入口 -->
    <view class="create-section card" bindtap="goToCreate">
      <view class="create-content">
        <image class="create-icon" src="/images/icons/create.png" mode="aspectFit"></image>
        <view class="create-text">
          <text class="create-title">发起招募</text>
          <text class="create-hint">创建一个新的约稿/约唱活动</text>
        </view>
      </view>
      <view class="create-arrow">›</view>
    </view>

    <!-- 关于 -->
    <view class="about-section">
      <text class="about-text">CarrotCast 萝卜坑 · 音乐约稿约唱平台</text>
    </view>

    <!-- 退出登录 -->
    <view class="logout-section">
      <button class="btn btn-logout" bindtap="onLogout">退出登录</button>
    </view>
  </block>
</view>

<!-- 登录提示弹窗 -->
<view class="modal-mask {{showLoginModal ? 'show' : ''}}" bindtap="hideLoginModal">
  <view class="modal-content modal-center" catchtap="preventBubble">
    <view class="modal-header">
      <text class="modal-title">温馨提示</text>
    </view>
    <view class="modal-body">
      <text class="modal-text">登录即表示同意</text>
      <text class="modal-link">《用户服务协议》</text>
      <text class="modal-text">和</text>
      <text class="modal-link">《隐私政策》</text>
    </view>
    <view class="modal-footer">
      <button class="btn btn-outline" bindtap="hideLoginModal">取消</button>
      <button class="btn btn-primary" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">确认登录</button>
    </view>
  </view>
</view>
