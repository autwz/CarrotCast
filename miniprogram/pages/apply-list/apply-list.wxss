/* 申请列表页面样式 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 招募信息 */
.recruitment-header {
  padding: 24rpx 30rpx;
  margin-bottom: 0;
  border-radius: 0;
}

.recruitment-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* 标签栏 */
.tabs {
  display: flex;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #FF6B6B;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #FF6B6B;
  border-radius: 3rpx;
}

/* 列表容器 */
.list-container {
  height: calc(100vh - 140rpx);
  padding: 24rpx;
}

.apply-list {
  display: flex;
  flex-direction: column;
}

.apply-card {
  margin-bottom: 24rpx;
}

.apply-header {
  margin-bottom: 20rpx;
}

.applicant-info {
  display: flex;
  align-items: center;
  position: relative;
}

.applicant-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.applicant-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.applicant-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.apply-meta {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}

.apply-role {
  font-size: 24rpx;
  color: #1890ff;
  background: #e6f7ff;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
}

.apply-time {
  font-size: 24rpx;
  color: #999;
}

.admin-badge {
  font-size: 24rpx;
  color: #faad14;
}

/* 申请内容 */
.apply-body {
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.apply-bio, .apply-message {
  margin-bottom: 16rpx;
}

.bio-label, .message-label {
  font-size: 26rpx;
  color: #666;
}

.bio-text, .message-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* 链接 */
.apply-links {
  margin: 16rpx 0;
}

.link-item {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.link-label {
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

.link-value {
  flex: 1;
  font-size: 24rpx;
  color: #1890ff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin: 0 12rpx;
}

.link-action {
  font-size: 24rpx;
  color: #FF6B6B;
  flex-shrink: 0;
}

/* 审核信息 */
.review-info {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
}

.review-status {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.review-status.status-approved {
  background: #f6ffed;
  color: #52c41a;
}

.review-status.status-rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

.review-message {
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.apply-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-sm {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  margin-left: 16rpx;
}

.set-admin {
  text-align: center;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #FF6B6B;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.modal-mask.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.modal-info {
  margin-bottom: 24rpx;
}

.info-text {
  font-size: 28rpx;
  color: #666;
}

.input-item {
  margin-bottom: 24rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.input-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #eee;
}

.modal-footer .btn {
  flex: 1;
  margin: 0 10rpx;
}
