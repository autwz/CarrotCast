/* 首页样式 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  width: 100%;
  overflow-x: hidden;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 14rpx 20rpx;
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.filter-tabs {
  display: flex;
}

.filter-tab {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 28rpx;
  margin-right: 12rpx;
  background: #f5f5f5;
}

.filter-tab.active {
  background: #FF6B6B;
  color: #fff;
}

.status-picker {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.arrow-icon {
  width: 22rpx;
  height: 22rpx;
  margin-left: 6rpx;
}

/* 招募列表 */
.recruitment-list {
  height: calc(100vh - 180rpx);
  padding: 16rpx;
  box-sizing: border-box;
}

.card-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.recruitment-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  width: calc(50% - 8rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-cover {
  position: relative;
  width: 100%;
  height: 200rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

/* 类型和状态标签并排容器 */
.card-tags-row {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  z-index: 10;
  overflow: visible;
}

/* 标签通用样式 */
.card-type, .card-status-tag {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  color: #fff;
  white-space: nowrap;
}

/* 类型标签颜色 */
.card-type.type-original {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
}

.card-type.type-cover {
  background: linear-gradient(135deg, #597ef7, #7b9fff);
}

/* 状态标签颜色 */
.card-status-tag.status-recruiting {
  background: linear-gradient(135deg, #1890ff, #69c0ff);
}

.card-status-tag.status-completed {
  background: linear-gradient(135deg, #faad14, #ffc53d);
}

.card-status-tag.status-published {
  background: linear-gradient(135deg, #52c41a, #73d13d);
}

.card-content {
  padding: 16rpx;
  padding-bottom: 12rpx;
  display: flex;
  flex-direction: column;
  min-height: 90rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* 卡片底部区域 - 截止日期靠右 */
.card-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: auto;
  padding-top: 8rpx;
}

.music-tag, .status-tag {
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.music-tag {
  background: #f5f5f5;
  color: #666;
}

.deadline-tag {
  background: #fff1f0;
  color: #FF6B6B;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
}

.status-tag.status-recruiting {
  background: #e6f7ff;
  color: #1890ff;
}

.status-tag.status-completed {
  background: #fff7e6;
  color: #faad14;
}

.status-tag.status-published {
  background: #f6ffed;
  color: #52c41a;
}

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: 24rpx;
  color: #999;
  font-size: 24rpx;
}

.load-more text {
  color: #FF6B6B;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-state image {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-state text {
  display: block;
  color: #999;
  font-size: 26rpx;
}
