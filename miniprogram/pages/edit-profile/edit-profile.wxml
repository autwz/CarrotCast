<view class="page">
  <view class="form-section">
    <!-- 头像 -->
    <view class="avatar-section card">
      <view class="avatar-preview" bindtap="chooseAvatar">
        <image class="avatar-image" src="{{formData.avatar || '/images/icons/avatar.png'}}" mode="aspectFill"></image>
        <view class="avatar-mask">
          <text class="avatar-hint">点击更换</text>
        </view>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="card">
      <view class="form-item">
        <text class="form-label">昵称</text>
        <input class="form-input" placeholder="请输入昵称" value="{{formData.nickname}}" bindinput="onInput" data-field="nickname" maxlength="20" />
      </view>

      <view class="form-item">
        <text class="form-label">简介</text>
        <textarea class="form-textarea" placeholder="介绍一下自己吧" value="{{formData.bio}}" bindinput="onInput" data-field="bio" maxlength="200"></textarea>
        <text class="form-counter">{{formData.bio.length || 0}}/200</text>
      </view>
    </view>



    <!-- 保存按钮 -->
    <view class="save-section">
      <button class="btn btn-primary save-btn" bindtap="saveProfile" loading="{{saving}}">保存</button>
    </view>
  </view>
</view>
